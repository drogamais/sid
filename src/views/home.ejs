<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SID Drogamais – Home</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            sid: { 50:'#fef2f2', 100:'#fee2e2', 200:'#fecaca', 500:'#c42c2c', 600:'#b91c1c', 700:'#991b1b' },
            ink: '#1e293b',
          },
          boxShadow: { panel: '0 8px 30px rgba(0,0,0,.06)' },
        },
      },
    };
  </script>
  <style>
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap');
  </style>
  <%- include('partials/sidebar_head') %>
</head>
<body data-admin="<%= !!(user && user.role === 'admin') %>" class="min-h-screen bg-[radial-gradient(circle_at_top,_#f8fafc,_#e2e8f0_100%)]">
  <div class="flex h-screen overflow-hidden">

    <%- include('partials/sidebar') %>

    <!-- ── Main ──────────────────────────────────────────────── -->
    <main class="flex-1 overflow-y-auto">
      <div class="mx-auto max-w-7xl p-8">

        <!-- Mobile header -->
        <div class="mb-6 flex items-center justify-between lg:hidden">
          <div class="flex h-12 shrink-0 items-center justify-center rounded-2xl bg-sid-600 px-4 font-bold tracking-widest text-white shadow-md">
            SID
          </div>
          <button id="backToHubBtnMobile" class="rounded-xl border border-slate-200 px-3 py-1.5 text-xs font-medium text-slate-500 hover:bg-slate-50 hover:text-sid-600">Voltar ao Hub</button>
        </div>

        <div class="space-y-6">
          <section class="grid gap-4 lg:grid-cols-3">
            <article class="rounded-3xl bg-white p-5 shadow-panel">
              <div class="mb-5 h-2 w-20 rounded-full bg-sky-500"></div>
              <p class="text-sm uppercase tracking-[0.2em] text-slate-500">Associadas</p>
              <h3 id="val-associadas" class="mt-3 text-4xl font-black text-ink">--</h3>
            </article>
            <article class="rounded-3xl bg-white p-5 shadow-panel">
              <div class="mb-5 h-2 w-20 rounded-full bg-emerald-500"></div>
              <p class="text-sm uppercase tracking-[0.2em] text-slate-500">Inauguradas</p>
              <h3 id="val-inauguradas" class="mt-3 text-4xl font-black text-ink">--</h3>
            </article>
            <article class="rounded-3xl bg-white p-5 shadow-panel">
              <div class="mb-5 h-2 w-20 rounded-full bg-rose-500"></div>
              <p class="text-sm uppercase tracking-[0.2em] text-slate-500">Layoutização</p>
              <h3 id="val-layoutzacao" class="mt-3 text-4xl font-black text-ink">--</h3>
            </article>
          </section>

          <section class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
            <article class="rounded-3xl bg-white p-6 shadow-panel">
              <div class="mb-6 flex items-center justify-between">
                <div>
                  <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Home</p>
                  <h3 class="text-2xl font-bold">Resumo operacional</h3>
                </div>
                <div class="rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-sid-700">SID</div>
              </div>
              <p class="max-w-2xl text-sm leading-7 text-slate-600">
                Esta nova versão em Fastify SSR nasce com foco em carregamento instantâneo, unificando frontend e backend no lado do servidor para alta performance e segurança. A identidade visual, gestão de lojas e regras de acesso continuam fiéis à plataforma de intranet.
              </p>
            </article>

            <article class="rounded-3xl bg-white p-6 shadow-panel">
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Perfis</p>
              <h3 class="mt-2 text-2xl font-bold">Regras de acesso</h3>
              <div class="mt-6 space-y-4 text-sm text-slate-600">
                <div class="rounded-2xl bg-slate-50 p-4">
                  <p class="font-semibold text-ink">Admin</p>
                  <p class="mt-1">Acessa Home e Lojas com permissão de escrita e edição (novo modelo SSR fastify).</p>
                </div>
                <div class="rounded-2xl bg-slate-50 p-4">
                  <p class="font-semibold text-ink">General</p>
                  <p class="mt-1">Acessa Home e Lojas apenas em modo leitura, sem botões de ação.</p>
                </div>
              </div>
            </article>
          </section>
        </div>

      </div>
    </main>
  </div>

  <%- include('partials/sidebar_scripts') %>
  <script>
    const HUB_URL = "http://localhost:8003";

    document.getElementById('backToHubBtnMobile')?.addEventListener('click', goLogout);

    function goLogout() {
      window.location.href = '/app/logout';
    }

    async function loadSummary() {
      try {
        const res = await fetch('/api/home/summary');
        if (!res.ok) {
          if (res.status === 401) {
            // Sessão morta, vai pro hub auth
            window.location.href = HUB_URL + '/login';
            return;
          }
          throw new Error('Falha ao buscar resumo');
        }
        const data = await res.json();
        document.getElementById('val-associadas').textContent = data.associadas ?? '--';
        document.getElementById('val-inauguradas').textContent = data.inauguradas ?? '--';
        document.getElementById('val-layoutzacao').textContent = data.layoutzacao ?? '--';
      } catch (err) {
        console.error(err);
      }
    }

    loadSummary();
  </script>
</body>
</html>
