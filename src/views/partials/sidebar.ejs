<!-- Sidebar partial (shared) -->
<aside id="sidebar" class="no-scrollbar flex flex-col overflow-y-auto border-r border-slate-200 bg-white lg:block hidden expanded">
  <div id="sidebarHeader" class="flex h-16 shrink-0 items-center justify-between border-b border-slate-100 bg-sid-600 px-4 font-bold tracking-widest text-white shadow-[0_4px_20px_-10px_rgba(225,29,72,0.4)]">
    <div id="sidebarBrand" class="flex items-center gap-3">
      <img id="sidebarLogoImg" src="/logo_drogamais.ico" alt="Drogamais" class="h-8 w-8 rounded-full object-cover bg-white" onerror="this.style.display='none';document.getElementById('sidebarLogoFallback').style.display='inline-flex'">
      <div id="sidebarLogoFallback" class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-white text-sid-600 font-bold" style="display:none">S</div>
      <div id="sidebarTitle" class="hidden lg:block nav-label">DROGAMAIS SID</div>
    </div>
    <button id="sidebarToggle" aria-label="Alternar sidebar" class="rounded-full bg-white/10 p-1 text-white hover:bg-white/20 focus:outline-none">
      <svg class="h-4 w-4 text-current" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
    </button>
  </div>
  <nav class="flex-1 space-y-1.5 p-4">
    <a href="/app/home" class="<%= active === 'home' ? 'flex items-center gap-3 rounded-2xl bg-sid-50 px-4 py-3 text-sm font-semibold text-sid-700 shadow-sm transition' : 'flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold text-slate-600 hover:bg-slate-50 hover:text-sid-600 transition' %>">
      <svg class="h-5 w-5 text-current" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span class="nav-label">Página Inicial</span>
    </a>
    <a href="/app/lojas" class="<%= active === 'lojas' ? 'flex items-center gap-3 rounded-2xl bg-sid-50 px-4 py-3 text-sm font-semibold text-sid-700 shadow-sm transition' : 'flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold text-slate-600 hover:bg-slate-50 hover:text-sid-600 transition' %>">
      <svg class="h-5 w-5 text-current" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
      <span class="nav-label">Lojas</span>
    </a>
  </nav>
  <div class="shrink-0 border-t border-slate-200 p-4">
    <div class="mb-4 rounded-2xl bg-slate-50 p-4">
      <p class="text-sm font-medium text-ink"><span class="nav-label"><%= user ? ((user.first_name || '') + ' ' + (user.last_name || '')).trim() || user.username : 'Usuário' %></span></p>
      <p class="mt-0.5 text-xs text-slate-500 capitalize"><span class="nav-label"><%= user ? user.role : '' %></span></p>
    </div>
    <button id="logoutBtn" class="flex w-full items-center gap-3 rounded-2xl px-4 py-3 text-sm font-medium text-slate-600 transition hover:bg-red-50 hover:text-red-700">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      <span class="nav-label">Sair do Sistema</span>
    </button>
  </div>
</aside>
