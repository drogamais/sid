<script>
  // Sidebar behavior: overlay, hover auto-collapse, and manual toggle
  (function () {
    const sidebar = document.getElementById('sidebar');
    if (!sidebar) return;
    const toggle = document.getElementById('sidebarToggle');
    const STORAGE_KEY = 'sidebarCollapsed';
    const AUTO_COLLAPSE = true;

    function setCollapsed(collapsed, persist = false) {
      sidebar.classList.toggle('collapsed', collapsed);
      sidebar.classList.toggle('expanded', !collapsed);
      if (persist) localStorage.setItem(STORAGE_KEY, collapsed ? 'true' : 'false');
    }

    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved === null) setCollapsed(true, false);
      else setCollapsed(saved === 'true', false);
    } catch (e) { setCollapsed(true, false); }

    if (AUTO_COLLAPSE) {
      sidebar.addEventListener('mouseenter', () => setCollapsed(false, false));
      sidebar.addEventListener('mouseleave', () => {
        const saved = localStorage.getItem(STORAGE_KEY);
        if (saved === 'false') return;
        setCollapsed(true, false);
      });
    }

    if (toggle) {
      toggle.addEventListener('click', () => {
        const now = sidebar.classList.contains('collapsed');
        setCollapsed(!now, true);
      });
    }

    document.getElementById('logoutBtn')?.addEventListener('click', () => window.location.href = 'http://localhost:8003/app/hub');
  })();
</script>

<!-- Silent refresh: Renovação de sessão nativa do SID (proxy para o Hub) -->
<script>
  (function() {
    const REFRESH_INTERVAL_MS = 45 * 1000; // 45 segundos para renovar o token de 60s

    async function doSilentRefresh() {
      try {
        const res = await fetch('/api/auth/refresh-session', {
          method: 'POST',
          credentials: 'include' // Garante o envio do cookie sid_refresh_token
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          console.warn('[SID] Falha na renovação silenciosa. Status:', res.status, data.error || '');
        } else {
          console.log('[SID] Sessão renovada com sucesso silenciosamente.');
        }
      } catch (err) {
        console.warn('[SID] Erro de rede ao tentar renovar a sessão.', err);
      }
    }

    // Intervalo começa pequeno (5s) mas o loop depois é a cada 45s.
    setTimeout(() => {
      doSilentRefresh();
      setInterval(doSilentRefresh, REFRESH_INTERVAL_MS);
    }, 5000);
  })();
</script>
