<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SID Drogamais</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            sid: { 50:'#fef2f2', 100:'#fee2e2', 200:'#fecaca', 500:'#c42c2c', 600:'#b91c1c', 700:'#991b1b' },
            ink: '#1e293b',
          },
          boxShadow: { panel: '0 8px 30px rgba(0,0,0,.06)' },
        },
      },
    };
  </script>
  <style>
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap');
  </style>
  <%- include('partials/sidebar_head') %>
  <!-- HTMX for progressive enhancement -->
  <script src="https://unpkg.com/htmx.org@1.9.3"></script>
</head>
<body data-admin="<%= !!(user && user.role === 'admin') %>" class="min-h-screen bg-[radial-gradient(circle_at_top,_#f8fafc,_#e2e8f0_100%)]">
  <div class="flex h-screen overflow-hidden">
    <%- include('partials/sidebar') %>

    <main class="flex-1 overflow-y-auto">
      <div class="mx-auto max-w-7xl p-8">
        <%- include('pages/' + page) %>
      </div>
    </main>
  </div>

  <%- include('partials/sidebar_scripts') %>
</body>
</html>
